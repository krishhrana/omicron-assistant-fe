# -----------------------------------------------------------------------------
# Dependencies / Package managers
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Framework + build output (Next.js / general frontend)
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/
.turbo/
.parcel-cache/
.cache/
.swc/

# -----------------------------------------------------------------------------
# TypeScript / bundler metadata
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Test, coverage, and reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Logs / runtime diagnostics
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.seed

# -----------------------------------------------------------------------------
# Environment and secrets
# Keep examples tracked, ignore all local env files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Deployment / hosting
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Tool caches
# -----------------------------------------------------------------------------
.eslintcache
.stylelintcache
.prettier-cache

# -----------------------------------------------------------------------------
# IDE / editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Temporary / backup files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.orig

# -----------------------------------------------------------------------------
# Optional local workspace scratch area
# -----------------------------------------------------------------------------
todos/

# -----------------------------------------------------------------------------
# Local certificates / keys
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt

# -----------------------------------------------------------------------------
# Legacy hooks path
# -----------------------------------------------------------------------------
.githooks/
